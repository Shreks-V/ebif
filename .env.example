# =========================
# Backend - Oracle Database
# =========================
ORACLE_USER=ADMIN
ORACLE_PASSWORD=your_oracle_password_here
ORACLE_DSN=your_oracle_dsn_here
ORACLE_CLIENT_DIR=
ORACLE_CONFIG_DIR=/wallet
ORACLE_WALLET_DIR=/wallet
ORACLE_WALLET_PASSWORD=your_wallet_password_here

# =========================
# Backend - App Security
# =========================
SECRET_KEY=change-this-to-a-secure-random-key

# =========================
# Backend - Cifrado de datos (AES-256-GCM / LFPDPPP)
# =========================
# Genera con: python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; print(base64.b64encode(AESGCM.generate_key(bit_length=256)).decode())"
DATA_ENCRYPTION_KEY=your_encryption_key_here

# =========================
# Backend - CORS
# =========================
CORS_ORIGINS=http://localhost,http://localhost:80

# =========================
# Qase TestOps (pytest reporter) — opcional
# =========================
# 1) En Qase: Apps → Pytest → Activar → Access tokens → crear token.
# 2) Código de proyecto Sprint 2: FJ26SV (ver qase.config.json).
# 3) No subas el token a git. Copia este archivo a .env (ya ignorado) o exporta:
#
#    export QASE_MODE=testops
#    export QASE_TESTOPS_API_TOKEN='tu_token'
#    export QASE_TESTOPS_PROJECT='FJ26SV'
#
# Sprint 2 — sincronizar casos en Qase antes de publicar resultados:
#    python scripts/qase_sync_sprint2.py
#    (o export QASE_SYNC_S2=1 para ejecutar sync al iniciar pytest)
#
# Enlazar Sprint 1 manualmente (ID numérico de la URL del caso en Qase):
#    export QASE_ID_FJ26SV_1=123
#
# GitHub Actions: Settings → Secrets → QASE_TESTOPS_API_TOKEN
QASE_MODE=off
QASE_TESTOPS_API_TOKEN=
QASE_TESTOPS_PROJECT=FJ26SV
QASE_SYNC_S2=0

# =========================
# Sprint 2 — pruebas (pruebas-s2/)
# =========================
# 0 = repos en memoria (CI y local por defecto)
# 1 = integración con Oracle (requiere ORACLE_* arriba)
EBIF_S2_USE_ORACLE=0
